<!DOCTYPE html>
<html>
<body>

<h3>Rejestracja</h3>

<form onsubmit="sprawdz(event)">
  <input id="email" placeholder="E-mail"><br><br>
  <input id="haslo" type="password" placeholder="Hasło"><br><br>
  <input id="haslo2" type="password" placeholder="Powtórz hasło"><br><br>

  <button>Zarejestruj</button>
</form>

<p id="msg" style="color:red;"></p>

<script>
function sprawdz(e) {
  e.preventDefault();

  let email = document.getElementById("email").value;
  let h1 = document.getElementById("haslo").value;
  let h2 = document.getElementById("haslo2").value;

  let msg = document.getElementById("msg");

  msg.textContent = "";

  if (!email.includes("@")) {
    msg.textContent = "Zły email";
  } else if (h1 !== h2) {
    msg.textContent = "Hasła nie są zgodne";
  } else {
    msg.style.color = "green";
    msg.textContent = "OK";
  }
}
</script>

</body>
</html>
