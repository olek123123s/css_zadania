<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 4</title>
</head>
<body>

<h2>Rejestracja</h2>

<form id="form">
  <input type="email" id="email" placeholder="E-mail"><br><br>
  <input type="password" id="password" placeholder="Hasło"><br><br>
  <input type="password" id="confirm" placeholder="Powtórz hasło"><br><br>
  <button type="submit">Zarejestruj</button>
</form>

<script>
document.getElementById("form").addEventListener("submit", function(e) {
  e.preventDefault();

  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;
  const confirm = document.getElementById("confirm").value;

  if (!email.includes("@")) {
    alert("Niepoprawny email");
    return;
  }

  if (password.length < 6) {
    alert("Hasło za krótkie");
    return;
  }

  if (password !== confirm) {
    alert("Hasła się nie zgadzają");
    return;
  }

  alert("OK!");
});
</script>

</body>
</html>
