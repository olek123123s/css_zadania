public class MeczPilkarski {
    private String przeciwnik;
    private int liczbaKibicow;
    private double cenaBiletu;
    private boolean czyWygrany;

    // Konstruktor domyślny
    public MeczPilkarski() {
    }

    // Konstruktor parametryczny
    public MeczPilkarski(String przeciwnik, int liczbaKibicow, double cenaBiletu, boolean czyWygrany) {
        this.przeciwnik = przeciwnik;
        setLiczbaKibicow(liczbaKibicow); // walidacja
        this.cenaBiletu = cenaBiletu;
        this.czyWygrany = czyWygrany;
    }

    // Gettery i settery
    public String getPrzeciwnik() {
        return przeciwnik;
    }

    public void setPrzeciwnik(String przeciwnik) {
        this.przeciwnik = przeciwnik;
    }

    public int getLiczbaKibicow() {
        return liczbaKibicow;
    }

    // WALIDACJA
    public void setLiczbaKibicow(int liczbaKibicow) {
        if (liczbaKibicow < 0) {
            System.out.println("BŁĄD: liczba kibiców nie może być ujemna!");
        } else {
            this.liczbaKibicow = liczbaKibicow;
        }
    }

    public double getCenaBiletu() {
        return cenaBiletu;
    }

    public void setCenaBiletu(double cenaBiletu) {
        this.cenaBiletu = cenaBiletu;
    }

    public boolean isCzyWygrany() {
        return czyWygrany;
    }

    public void setCzyWygrany(boolean czyWygrany) {
        this.czyWygrany = czyWygrany;
    }

    // Metoda biznesowa
    public double obliczPrzychod() {
        return liczbaKibicow * cenaBiletu;
    }

    @Override
    public String toString() {
        return "Przeciwnik: " + przeciwnik +
                ", Kibice: " + liczbaKibicow +
                ", Cena biletu: " + cenaBiletu +
                ", Wygrany: " + (czyWygrany ? "Tak" : "Nie");
    }
}
