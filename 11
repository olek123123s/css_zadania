<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 1</title>
</head>
<body>

<h2>Poziom 1 - Podstawy String</h2>

<div id="wyniki"></div>

<script>

let tekst = " Programowanie jest super! ";

let wyniki = `
<p>Długość tekstu: ${tekst.length}</p>
<p>Bez spacji: ${tekst.trim()}</p>
<p>Wielkie litery: ${tekst.toUpperCase()}</p>
<p>Czy zawiera "super": ${tekst.includes("super")}</p>
`;

document.getElementById("wyniki").innerHTML = wyniki;

</script>

</body>
</html>
