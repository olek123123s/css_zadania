<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <title>Poziom 4 - Dziedziczenie</title>

  <style>
    body {
      font-family: Arial;
      padding: 20px;
      background: #f4f4f4;
    }

    #wynik {
      background: white;
      padding: 15px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      line-height: 1.8;
    }
  </style>
</head>
<body>

<h2>Poziom 4 — Dziedziczenie i Enkapsulacja</h2>

<div id="wynik"></div>

<script>
  // funkcja do wyświetlania na stronie
  function pokaz(tekst) {
    document.getElementById("wynik").innerHTML += tekst + "<br>";
  }

  // 16. Klasa Osoba
  class Osoba {
    constructor(imie, wiek) {
      this.imie = imie;
      this._wiek = wiek;
    }

    przywitaj() {
      pokaz(`Cześć, mam na imię ${this.imie}.`);
    }

    get wiek() {
      return this._wiek;
    }

    set wiek(nowyWiek) {
      if (nowyWiek < 0) {
        pokaz("❌ Błąd: wiek nie może być mniejszy niż 0!");
      } else {
        this._wiek = nowyWiek;
      }
    }
  }

  // 17. Nauczyciel dziedziczy po Osoba
  class Nauczyciel extends Osoba {
    #pensja;

    constructor(imie, wiek, przedmiot, pensja) {
      super(imie, wiek);
      this.przedmiot = przedmiot;
      this.#pensja = pensja;
    }

    ucz() {
      pokaz(`${this.imie} uczy przedmiotu: ${this.przedmiot}`);
    }

    // 18. Nadpisana metoda
    przywitaj() {
      pokaz(`Dzień dobry, jestem ${this.imie} i uczę ${this.przedmiot}.`);
    }

    // 20. metoda zwracająca prywatną pensję
    pobierzPensje() {
      return this.#pensja;
    }
  }

  // ===== Test =====
  const nauczyciel = new Nauczyciel("Anna", 30, "Matematyka", 6000);

  nauczyciel.przywitaj();
  nauczyciel.ucz();

  pokaz("Wiek: " + nauczyciel.wiek);

  nauczyciel.wiek = -5; // błąd
  nauczyciel.wiek = 40;

  pokaz("Nowy wiek: " + nauczyciel.wiek);
  pokaz("Pensja: " + nauczyciel.pobierzPensje());
</script>

</body>
</html>
