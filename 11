import java.util.ArrayList;

public class SezonLigi {
    private ArrayList<MeczPilkarski> mecze;

    public SezonLigi() {
        mecze = new ArrayList<>();

        // dane startowe
        mecze.add(new MeczPilkarski("Barcelona", 50000, 120, true));
        mecze.add(new MeczPilkarski("Real", 60000, 150, false));
    }

    public void dodajMecz(MeczPilkarski mecz) {
        mecze.add(mecz);
    }

    public void wyswietl() {
        if (mecze.isEmpty()) {
            System.out.println("Brak meczów!");
            return;
        }

        for (MeczPilkarski m : mecze) {
            System.out.println(m);
        }
    }

    // metoda analityczna
    public void najlepszyPrzychod() {
        if (mecze.isEmpty()) return;

        MeczPilkarski best = mecze.get(0);

        for (MeczPilkarski m : mecze) {
            if (m.getPrzychod() > best.getPrzychod()) {
                best = m;
            }
        }

        System.out.println("\nNajwiększy przychód:");
        System.out.println(best);
    }
}
