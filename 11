<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Poziom 1 - Podstawy obiektów</title>
</head>
<body>

<h1>POZIOM 1 – PODSTAWY OBIEKTÓW</h1>

<div id="wynik"></div>

<script>
let output = "";

// 1. Obiekt książka
let ksiazka = {
    tytul: "Władca Pierścieni",
    autor: "J.R.R. Tolkien",
    rokWydania: 1954,
    opis: function() {
        return "Tytuł: " + this.tytul + ", Autor: " + this.autor;
    }
};

// 2. Wypisanie właściwości
output += "<h3>Właściwości książki:</h3>";
for (let klucz in ksiazka) {
    if (typeof ksiazka[klucz] !== "function") {
        output += klucz + ": " + ksiazka[klucz] + "<br>";
    }
}

// 3. Metoda opis()
output += "<br><b>Opis:</b> " + ksiazka.opis() + "<br>";

// 4. Zmiana właściwości
ksiazka.rokWydania = 2000;
output += "<br>Nowy rok wydania: " + ksiazka.rokWydania + "<br>";

// 5. Sprawdzenia
output += "<br>Czy ma właściwość 'wydawnictwo'? " + 
          ksiazka.hasOwnProperty("wydawnictwo") + "<br>";

output += "Liczba właściwości: " + 
          Object.keys(ksiazka).length + "<br>";

// 6. Tablica produktów
let produkty = [
    { nazwa: "Telefon", cena: 3000 },
    { nazwa: "Laptop", cena: 5000 },
    { nazwa: "Monitor", cena: 1200 }
];

output += "<br><h3>Produkty:</h3>";
produkty.forEach(p => {
    output += p.nazwa + "<br>";
});

document.getElementById("wynik").innerHTML = output;
</script>

</body>
</html>
