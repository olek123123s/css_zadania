<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 3</title>
</head>
<body>

<h2>Sprawdzanie PESEL</h2>

<input id="pesel" placeholder="Wpisz PESEL">
<button onclick="sprawdz()">Sprawdź</button>

<p id="wynik"></p>
<p id="maskowany"></p>

<script>

function sprawdz(){

let pesel = document.getElementById("pesel").value;
let wynik = document.getElementById("wynik");
let maskowany = document.getElementById("maskowany");

if(pesel.length === 11){
wynik.textContent = "PESEL poprawny";
wynik.style.color = "green";
}else{
wynik.textContent = "Błąd - PESEL musi mieć 11 znaków";
wynik.style.color = "red";
}

maskowany.textContent = "Maskowany PESEL: " + maskujPesel(pesel);

}

function maskujPesel(pesel){

let koniec = pesel.slice(-4);
return "*******" + koniec;

}

</script>

</body>
</html>
