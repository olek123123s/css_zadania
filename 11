<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 3 - Obiekty + DOM</title>
<style>
    body { font-family: Arial; }
    .produkt {
        border: 1px solid black;
        padding: 10px;
        margin: 10px;
        width: 250px;
    }
    button { margin-right: 5px; }
</style>
</head>
<body>

<h1>POZIOM 3 – OBIEKTY + DOM</h1>
<div id="produkty"></div>

<script>

class Produkt {
    constructor(nazwa, cena) {
        this.nazwa = nazwa;
        this.cena = cena;
    }

    render() {
        const div = document.createElement("div");
        div.className = "produkt";

        const info = document.createElement("p");
        info.innerText = this.nazwa + " - " + this.cena + " zł";

        // Przycisk usuń
        const usunBtn = document.createElement("button");
        usunBtn.innerText = "Usuń";
        usunBtn.onclick = () => div.remove();

        // Przycisk promocja
        const promoBtn = document.createElement("button");
        promoBtn.innerText = "Promocja -20%";
        promoBtn.onclick = () => {
            this.cena = (this.cena * 0.8).toFixed(2);
            info.innerText = this.nazwa + " - " + this.cena + " zł";
        };

        div.appendChild(info);
        div.appendChild(usunBtn);
        div.appendChild(promoBtn);

        document.getElementById("produkty").appendChild(div);
    }
}

// 4 produkty
const produkty = [
    new Produkt("Telefon", 3000),
    new Produkt("Laptop", 5000),
    new Produkt("Monitor", 1200),
    new Produkt("Klawiatura", 300)
];

// generowanie na stronie
produkty.forEach(p => p.render());

</script>

</body>
</html>
