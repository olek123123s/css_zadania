<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Poziom 2 - Konstruktor i Class</title>
</head>
<body>

<h1>POZIOM 2 – KONSTRUKTOR I CLASS</h1>

<div id="wynik"></div>

<script>
let output = "";

// 6. Konstruktor
function Uczen(imie, nazwisko, klasa) {
    this.imie = imie;
    this.nazwisko = nazwisko;
    this.klasa = klasa;

    this.przedstawSie = function() {
        return "Nazywam się " + this.imie + " " +
               this.nazwisko + 
               " i chodzę do klasy " + this.klasa;
    };
}

// 8. 3 uczniów
let u1 = new Uczen("Jan", "Kowalski", "3A");
let u2 = new Uczen("Anna", "Nowak", "2B");
let u3 = new Uczen("Piotr", "Wiśniewski", "1C");

output += "<h3>Uczniowie (konstruktor):</h3>";
output += u1.przedstawSie() + "<br>";
output += u2.przedstawSie() + "<br>";
output += u3.przedstawSie() + "<br>";

// 9. Wersja class
class UczenClass {
    constructor(imie, nazwisko, klasa) {
        this.imie = imie;
        this.nazwisko = nazwisko;
        this.klasa = klasa;
    }

    przedstawSie() {
        return "Nazywam się " + this.imie + " " +
               this.nazwisko + 
               " i chodzę do klasy " + this.klasa;
    }

    // 10. Inicjały
    inicjaly() {
        return this.imie[0] + this.nazwisko[0];
    }
}

let u4 = new UczenClass("Kasia", "Lewandowska", "4D");

output += "<br><h3>Uczeń (class):</h3>";
output += u4.przedstawSie() + "<br>";
output += "Inicjały: " + u4.inicjaly();

document.getElementById("wynik").innerHTML = output;
</script>

</body>
</html>
