<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 1</title>
</head>
<body>

<img id="photo" src="https://picsum.photos/300?1" width="300">
<br><br>

<button onclick="changePhoto()">Zmień zdjęcie</button>
<button onclick="resetPhoto()">Reset</button>

<script>
const original = "https://picsum.photos/300?1";

function changePhoto() {
    document.getElementById("photo").src = "https://picsum.photos/300?2";
}

function resetPhoto() {
    document.getElementById("photo").src = original;
}
</script>

</body>
</html>
