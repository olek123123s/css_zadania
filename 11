<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 2</title>
</head>
<body>

<h2>Poziom 2 - Wycinanie i szukanie</h2>

<div id="wyniki"></div>

<script>

let dane = "Marcin;Kowalski;30;Gdańsk";
let nazwisko = dane.split(";")[1];

function czyPolskiEmail(mail){
return mail.endsWith(".pl");
}

let zdanie = "Lubię koty, bo koty są puszyste";
let nowe = zdanie.replace("koty","psy");

let imie = "Marcin";
let pierwsza = imie.at(0);
let ostatnia = imie.at(-1);

document.getElementById("wyniki").innerHTML = `
<p>Nazwisko: ${nazwisko}</p>
<p>Email test@gmail.pl kończy się na .pl: ${czyPolskiEmail("test@gmail.pl")}</p>
<p>Email test@gmail.com kończy się na .pl: ${czyPolskiEmail("test@gmail.com")}</p>
<p>Zmiana zdania: ${nowe}</p>
<p>Pierwsza litera imienia: ${pierwsza}</p>
<p>Ostatnia litera imienia: ${ostatnia}</p>
`;

</script>

</body>
</html>
