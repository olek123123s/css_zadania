import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        SezonLigi sezon = new SezonLigi();

        int wybor;

        do {
            System.out.println("\n--- MENU ---");
            System.out.println("1. Dodaj mecz");
            System.out.println("2. Wyświetl mecze");
            System.out.println("3. Największy przychód");
            System.out.println("4. Test walidacji");
            System.out.println("0. Wyjście");

            wybor = sc.nextInt();
            sc.nextLine();

            switch (wybor) {
                case 1:
                    System.out.print("Przeciwnik: ");
                    String przeciwnik = sc.nextLine();

                    System.out.print("Liczba kibiców: ");
                    int kibice = sc.nextInt();

                    System.out.print("Cena biletu: ");
                    double cena = sc.nextDouble();

                    System.out.print("Czy wygrany (true/false): ");
                    boolean wygrany = sc.nextBoolean();

                    sezon.dodajMecz(new MeczPilkarski(przeciwnik, kibice, cena, wygrany));
                    break;

                case 2:
                    sezon.wyswietl();
                    break;

                case 3:
                    sezon.najlepszyPrzychod();
                    break;

                case 4:
                    System.out.println("Test walidacji:");
                    MeczPilkarski test = new MeczPilkarski();
                    test.setLiczbaKibicow(-10); // powinien pokazać błąd
                    break;
            }

        } while (wybor != 0);

        sc.close();
    }
}
